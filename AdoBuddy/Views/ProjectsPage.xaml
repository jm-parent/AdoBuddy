<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AdoBuddy.ViewModels"
             xmlns:models="clr-namespace:AdoBuddy.Models"
             x:Class="AdoBuddy.Views.ProjectsPage"
             x:DataType="vm:ProjectsViewModel"
             Title="Projects">

    <Grid RowDefinitions="Auto,*">

        <!-- Header bar -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="20,16">
            <Label Text="Select a Project" FontSize="22" FontAttributes="Bold"
                   TextColor="White" />
            <Label Text="Choose an Azure DevOps project to explore"
                   FontSize="13" TextColor="#CCE8FF" />
        </VerticalStackLayout>

        <!-- Content -->
        <Grid Grid.Row="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               VerticalOptions="Center" HorizontalOptions="Center" />

            <CollectionView ItemsSource="{Binding Projects}"
                            IsVisible="{Binding IsNotBusy}"
                            SelectionMode="Single"
                            SelectionChanged="OnProjectSelected"
                            Margin="16,12">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AzureDevOpsProject">
                        <Frame CornerRadius="12" HasShadow="True" Padding="16"
                               Margin="0,0,0,10"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Project icon -->
                                <Frame Grid.Column="0" CornerRadius="10"
                                       BackgroundColor="{StaticResource Primary}"
                                       WidthRequest="44" HeightRequest="44" Padding="0"
                                       VerticalOptions="Center" Margin="0,0,12,0">
                                    <Label Text="&#xf07b;" FontFamily="FontAwesomeSolid"
                                           FontSize="20" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                                <!-- Name + description -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="13" Opacity="0.6"
                                           MaxLines="1" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <!-- Chevron -->
                                <Label Grid.Column="2" Text="&#xf054;" FontFamily="FontAwesomeSolid"
                                       FontSize="14" Opacity="0.4" VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>

</ContentPage>
