<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AdoBuddy.ViewModels"
             xmlns:models="clr-namespace:AdoBuddy.Models"
             x:Class="AdoBuddy.Views.PullRequestsPage"
             x:DataType="vm:PullRequestsViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0" Padding="16,8" Spacing="8">
            <Entry Placeholder="Project name"
                   Text="{Binding ProjectName}" />
            <Button Text="Load Pull Requests"
                    Command="{Binding LoadPullRequestsCommand}"
                    HorizontalOptions="Fill" />
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding PullRequests}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PullRequest">
                    <Border Padding="16,8" Margin="8,4" StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="16" />
                            <Label Text="{Binding CreatedBy}" />
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding SourceBranch}" FontSize="12" />
                                <Label Text="→" FontSize="12" />
                                <Label Text="{Binding TargetBranch}" FontSize="12" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
