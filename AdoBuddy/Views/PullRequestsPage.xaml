<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AdoBuddy.ViewModels"
             xmlns:models="clr-namespace:AdoBuddy.Models"
             x:Class="AdoBuddy.Views.PullRequestsPage"
             x:DataType="vm:PullRequestsViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto">
        <ActivityIndicator Grid.RowSpan="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <CollectionView Grid.Row="0" ItemsSource="{Binding PullRequests}" Margin="12,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PullRequest">
                    <Frame CornerRadius="10" HasShadow="True" Padding="16" Margin="0,0,0,8"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Title}"
                                       FontSize="15" FontAttributes="Bold"
                                       MaxLines="2" LineBreakMode="TailTruncation" />
                                <Frame Grid.Column="1" CornerRadius="12" Padding="8,4"
                                       BackgroundColor="#28A745">
                                    <Label Text="{Binding Status}" FontSize="11" TextColor="White" />
                                </Frame>
                            </Grid>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding SourceBranch}" FontSize="12" Opacity="0.6" />
                                <Label Text="→" FontSize="12" Opacity="0.5" />
                                <Label Text="{Binding TargetBranch}" FontSize="12" Opacity="0.6" />
                            </HorizontalStackLayout>                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding Id, StringFormat='PR #{0}'}" FontSize="12" Opacity="0.5" />
                                <Label Text="by" FontSize="12" Opacity="0.5" />
                                <Label Text="{Binding CreatedBy}" FontSize="12" Opacity="0.6" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="1" Text="{Binding ErrorMessage}" TextColor="Red"
               IsVisible="{Binding HasError}" Margin="16,8" FontSize="13" />
    </Grid>

</ContentPage>

