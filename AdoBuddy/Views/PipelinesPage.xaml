<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AdoBuddy.ViewModels"
             xmlns:models="clr-namespace:AdoBuddy.Models"
             x:Class="AdoBuddy.Views.PipelinesPage"
             x:DataType="vm:PipelinesViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto">
        <ActivityIndicator Grid.RowSpan="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <CollectionView Grid.Row="0" ItemsSource="{Binding PipelineRuns}" Margin="12,8">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PipelineRun">
                    <Frame CornerRadius="10" HasShadow="True" Padding="16" Margin="0,0,0,8"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding PipelineName}" FontSize="15" FontAttributes="Bold" />
                            <!-- Result badge -->
                            <Frame Grid.Row="0" Grid.Column="1" CornerRadius="12" Padding="10,4">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Result}" Value="succeeded">
                                        <Setter Property="BackgroundColor" Value="#28A745" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Result}" Value="failed">
                                        <Setter Property="BackgroundColor" Value="#DC3545" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Result}" Value="canceled">
                                        <Setter Property="BackgroundColor" Value="#6C757D" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <Label Text="{Binding Result}" FontSize="11" TextColor="White" />
                            </Frame>
                            <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="12" Margin="0,6,0,0">
                                <Label Text="{Binding Status}" FontSize="12" Opacity="0.6" />
                                <Label Text="{Binding StartTime, StringFormat='{0:MMM dd HH:mm}'}"
                                       FontSize="12" Opacity="0.6" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label Grid.Row="1" Text="{Binding ErrorMessage}" TextColor="Red"
               IsVisible="{Binding HasError}" Margin="16,8" FontSize="13" />
    </Grid>

</ContentPage>

