<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AdoBuddy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AdoBuddy"
    xmlns:views="clr-namespace:AdoBuddy.Views"
    Title="AdoBuddy">

    <!-- Login — no chrome -->
    <ShellContent Route="LoginPage"
                  Shell.NavBarIsVisible="False"
                  Shell.TabBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:LoginPage}" />

    <!-- Projects list — no flyout, no tab bar -->
    <ShellContent Route="ProjectsPage"
                  Shell.FlyoutBehavior="Disabled"
                  Shell.TabBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:ProjectsPage}" />

    <!-- Per-project flyout navigation -->
    <FlyoutItem x:Name="ProjectShell"
                Route="ProjectShell"
                Title="{Binding CurrentProjectName, Source={RelativeSource Self}}">
        <Tab Title="Pull Requests">
            <ShellContent Route="PullRequestsPage"
                          ContentTemplate="{DataTemplate views:PullRequestsPage}" />
        </Tab>
        <Tab Title="Backlog">
            <ShellContent Route="WorkItemsPage"
                          ContentTemplate="{DataTemplate views:WorkItemsPage}" />
        </Tab>
        <Tab Title="Pipelines">
            <ShellContent Route="PipelinesPage"
                          ContentTemplate="{DataTemplate views:PipelinesPage}" />
        </Tab>
    </FlyoutItem>

</Shell>
